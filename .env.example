# MySQL-Verbindung
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=schulungshub
DB_PASS=hier_passwort_eintragen

# Datenbankname (wird automatisch erstellt)
DB_NAME=schulungshub

# HTTP-Port
PORT=8080

# Secure-Cookies (true = HTTPS erforderlich, false = HTTP reicht)
SECURE_COOKIES=false

# Setup-Key (wird beim Anlegen der ersten Abteilung gebraucht)
SETUP_KEY=hier_beliebigen_schluessel_eintragen
