# =============================================
# SchulungsHub – Konfiguration
# =============================================
# Diese Datei nach ".env" kopieren und anpassen:
#   cp .env.example .env
#
# Danach Server starten:
#   ./schulungshub-linux-amd64
#
# Erste Abteilung + Admin-User anlegen:
#   ./create-dept.sh "Siebdruck" siebdruck admin "MeinPasswort123!"
#
# Weitere Abteilung anlegen:
#   ./create-dept.sh "Spritzguss" spritzguss admin "AnderesPasswort!"
#
# Dann im Browser oeffnen:
#   http://<server-ip>:8080
# =============================================

# MySQL-Verbindung
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=schulungshub
DB_PASS=hier_passwort_eintragen

# Datenbankname (wird automatisch erstellt)
DB_NAME=schulungshub

# HTTP-Port
PORT=8080

# Secure-Cookies (true = nur mit HTTPS, false = auch ohne HTTPS)
SECURE_COOKIES=false

# Setup-Key (frei waehlbar, wird nur beim Anlegen von Abteilungen gebraucht)
SETUP_KEY=hier_beliebigen_schluessel_eintragen
